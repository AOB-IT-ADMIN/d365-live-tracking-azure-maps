# ─────────────────────────────────────────────────────────────
# D365 Live Tracking — Environment Variables Example
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────

# Azure Maps Subscription Key
# Get from: portal.azure.com → Azure Maps account → Authentication → Shared Key
AZURE_MAPS_KEY=YOUR_AZURE_MAPS_SUBSCRIPTION_KEY

# ─────────────────────────────────────────────────────────────
# The following values are entered by the user at runtime
# in the mobile app Connection Setup screen.
# They are NOT stored in code — only in the device Keychain.
# ─────────────────────────────────────────────────────────────

# Azure AD Application (Client) ID
# Get from: portal.azure.com → App Registrations → your app → Overview
AZURE_AD_CLIENT_ID=YOUR_AZURE_AD_CLIENT_ID

# Dynamics 365 CRM URL
# Example: https://yourorg.crm.dynamics.com
D365_ORG_URL=https://yourorg.crm.dynamics.com
